NEXT_PUBLIC_BACKEND_URL=

# NextAuth.js Configuration
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Your app URL (required for production)
# AUTH_URL=https://yourdomain.com

# Maintenance Mode: Set to "true" to show a maintenance page
# MAINTENANCE_MODE=true

# Google Analytics Measurement ID (starts with G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry Configuration (for error logging)
# Get your DSN from Sentry: Settings > Projects > [Your Project] > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization and project slugs (required for source map uploads)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry Auth Token (required for source map uploads during build)
# Generate at: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
